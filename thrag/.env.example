VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_VLLM_ORIGIN=http://localhost:8000
VITE_VLLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
VITE_REGULAR_LLM_MODEL=openai/gpt-4o-mini
REGULAR_LLM_API_KEY=your-regular-llm-api-key
REGULAR_LLM_ORIGIN=https://openrouter.ai/api
REGULAR_LLM_CHAT_PATH=/v1/chat/completions
RAG_SECURITY_SCRIPT_PATH=/absolute/path/to/rag_security_assessment.py
# On Vercel, POST /api/rag-security-assessment is handled by api/rag-security-assessment.js
# (same stub output as scripts/rag_security_assessment.py). Optional overrides:
# RAG_VLLM_MODEL, RAG_VLLM_ORIGIN, RAG_VLLM_CHAT_PATH
# Per-IP fixed window limits (in-memory; applies to Vite dev + preview API routes)
REGULAR_LLM_RATE_LIMIT_MAX=30
REGULAR_LLM_RATE_LIMIT_WINDOW_MS=60000
RAG_RATE_LIMIT_MAX=5
RAG_RATE_LIMIT_WINDOW_MS=60000
